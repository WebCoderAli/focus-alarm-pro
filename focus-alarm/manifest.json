{
  "manifest_version": 3,
  "name": "Focus Alarm Pro",
  "version": "1.1",
  "description": "Close tabs after entertainment time ends.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "tabs",
    "alarms",
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}